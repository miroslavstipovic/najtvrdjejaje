# Database - Prisma Accelerate pooled connection (prisma:// protocol)
# Get this from your Prisma Accelerate dashboard at https://console.prisma.io/accelerate
PRISMA_POSTGRES="prisma://your-accelerate-connection-string"

# Database - Direct URL for migrations (postgresql:// protocol)
# Use your original database connection without pooling for migrations
DIRECT_URL="postgresql://user:password@host:port/database?schema=public"

# JWT Secret for authentication (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-secure-jwt-secret-here"

# Next.js public API URL
NEXT_PUBLIC_API_URL="https://your-vercel-deployment.vercel.app"

