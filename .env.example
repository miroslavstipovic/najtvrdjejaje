# Database - Connection pooling URL (required for serverless environments like Vercel)
# For local development: use postgres:// protocol
# For Vercel: get this from Vercel dashboard or your database provider
DATABASE_URL="postgres://user:password@host:port/database?schema=public"

# Database - Direct URL (required for Prisma migrations)
# Use the same URL as DATABASE_URL for local development
# For Vercel: same as DATABASE_URL usually
DIRECT_URL="postgresql://user:password@host:port/database?schema=public"

# JWT Secret for authentication
JWT_SECRET="your-secret-key-here"

# Next.js public API URL
NEXT_PUBLIC_API_URL="http://localhost:3000"
